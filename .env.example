# Research Finder — Environment Variables
# No API keys required! Both OpenAlex and CrossRef are free and open.

# Your email (used as polite identifier in API requests for better rate limits)
CONTACT_EMAIL=your-email@example.com

# Redis connection (leave defaults for Docker Compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Cache TTLs in seconds
CACHE_TTL_SEARCH=3600
CACHE_TTL_PAPER=86400

# Flask env
FLASK_ENV=production
PORT=5000
